@startuml
skinparam classAttributeIconSize 0

class Користувач {
  ім'я: String
  PIN: int
  номерКартки: String
  баланс: float
  статус: String
  --
  авторизація(): bool
  знятиГроші(): void
  перевіритиБаланс(): float
  поповнитиРахунок(): void
  змінитиPIN(): void
}

class Адміністратор {
  id: int
  ім'я: String
  доступ: String
  логін: String
  пароль: String
  --
  перевіритиСтан(): void
  переглянутиЖурнал(): void
  поповнитиБанкомат(): void
  авторизація(): bool
  керування(): void
}

class ТехнічнийПерсонал {
  id: int
  ім'я: String
  спеціалізація: String
  досвід: int
  статус: String
  --
  діагностика(): void
  ремонт(): void
  обслуговування(): void
  перевірка(): void
  звіт(): void
}

class БанківськаКартка {
  номер: String
  дата: Date
  CVV: int
  статус: String
  тип: String
  --
  перевірка(): bool
  активувати(): void
  деактивувати(): void
  змінитиPIN(): void
  отриматиДані(): String
}

class Рахунок {
  номер: String
  баланс: float
  валюта: String
  тип: String
  статус: String
  --
  поповнити(): void
  зняти(): void
  перевіритиБаланс(): float
  заблокувати(): void
  розблокувати(): void
}

class Транзакція {
  id: int
  сума: float
  дата: Date
  тип: String
  статус: String
  --
  виконати(): void
  скасувати(): void
  перевірити(): bool
  зберегти(): void
  отримати(): String
}

class Банкомат {
  id: int
  місце: String
  статус: String
  баланс: float
  модель: String
  --
  видатиГроші(): void
  прийнятиГроші(): void
  перевірка(): void
  друкЧека(): void
  оновлення(): void
}

class СерверБанку {
  IP: String
  статус: String
  навантаження: float
  порт: int
  версія: String
  --
  обробитиЗапит(): void
  перевіритиДані(): bool
  підключення(): bool
  логування(): void
  оновлення(): void
}

class БазаДаних {
  назва: String
  тип: String
  розмір: int
  статус: String
  версія: String
  --
  зберегти(): void
  видалити(): void
  оновити(): void
  знайти(): String
  підключення(): bool
}

class Чек {
  номер: int
  дата: Date
  сума: float
  тип: String
  статус: String
  --
  створити(): void
  друк(): void
  зберегти(): void
  отримати(): String
  видалити(): void
}

Користувач <|-- Адміністратор
Користувач <|-- ТехнічнийПерсонал
Користувач o-- БанківськаКартка
Користувач -- Рахунок
Банкомат *-- Чек
Банкомат --> СерверБанку
СерверБанку --> БазаДаних
Рахунок --> Транзакція
@enduml
